{
    "name": "engfabiodesalvi/busca-cep-php",
    "description": "Biblioteca PHP para consulta de CEP utilizando múltiplos provedores",
    "type": "library",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "license": "MIT",

    "keywords": [
        "cep",
        "viacep",
        "webmania",
        "widenet",
        "brasilapi",
        "opencep",
        "awesomeapi",
        "php",
        "address",
        "postal-code"
    ],

    "autoload": {
        "psr-4": {
            "Engfabiodesalvi\\BuscaCepPhp\\": "src/"
        }
    },

    "autoload-dev": {
        "psr-4": {
            "Engfabiodesalvi\\BuscaCepPhp\\Tests\\": "tests/"
        }
    },

    "authors": [
        {
            "name": "Fabio Toledo Bonemer De Salvi",
            "email": "engfabiodesalvi@gmail.com"
        }
    ],
    "require": {
        "php":">=8.3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.5"
    }
}
